# Defense for: submission_ptrace.py
# Blocks SYS_ptrace (syscall 101) via seccomp BPF filter in landlock.cpp
#
# IMPORTANT: PR_SET_NO_NEW_PRIVS must be set ONCE at the top of
# install_landlock(), BEFORE any seccomp filters. Without it, all
# seccomp filters silently fail.
#
# Tested: full rebuild of pygpubench on Modal (L4 GPU, CUDA 13.0, Ubuntu 24.04)
# Without patch: PTRACE_ATTACH succeeds, exploit reports 1.0 us
# With patch:    PTRACE_ATTACH returns EPERM, falls back to real timing (~55 us)

--- a/csrc/landlock.cpp
+++ b/csrc/landlock.cpp
@@ -4,6 +4,9 @@
 #include <cstdint>
 #include <fcntl.h>
 #include <stddef.h>
+#include <cstring>
+#include <linux/filter.h>
+#include <linux/seccomp.h>
 #include <stdio.h>
 #include <stdlib.h>
 #include <sys/prctl.h>
@@ -76,6 +79,49 @@
 }

 void install_landlock() {
+    // Required for ALL seccomp filters below -- must be first
+    prctl(PR_SET_NO_NEW_PRIVS, 1, 0, 0, 0);
+
+    // === DEFENSE: Block SYS_ptrace via seccomp BPF ===
+    {
+        struct sock_filter filter[] = {
+            BPF_STMT(BPF_LD | BPF_W | BPF_ABS,
+                     offsetof(struct seccomp_data, nr)),
+            BPF_JUMP(BPF_JMP | BPF_JEQ | BPF_K, __NR_ptrace, 0, 1),
+            BPF_STMT(BPF_RET | BPF_K, SECCOMP_RET_ERRNO | 1),
+            BPF_STMT(BPF_RET | BPF_K, SECCOMP_RET_ALLOW),
+        };
+        struct sock_fprog prog = {
+            .len = sizeof(filter) / sizeof(filter[0]),
+            .filter = filter,
+        };
+        if (syscall(__NR_seccomp, SECCOMP_SET_MODE_FILTER, 0, &prog) < 0) {
+            fprintf(stderr, "seccomp(block ptrace): %s\n", strerror(errno));
+        }
+    }
+
+    // === DEFENSE: Block prctl(PR_SET_DUMPABLE, 1) via seccomp BPF ===
+    // gVisor may not intercept ptrace via seccomp; blocking SET_DUMPABLE
+    // prevents the attacker from making the process dumpable for PTRACE_ATTACH.
+    {
+        struct sock_filter filter[] = {
+            BPF_STMT(BPF_LD | BPF_W | BPF_ABS,
+                     offsetof(struct seccomp_data, nr)),
+            BPF_JUMP(BPF_JMP | BPF_JEQ | BPF_K, __NR_prctl, 0, 5),
+            BPF_STMT(BPF_LD | BPF_W | BPF_ABS,
+                     offsetof(struct seccomp_data, args[0])),
+            BPF_JUMP(BPF_JMP | BPF_JEQ | BPF_K, PR_SET_DUMPABLE, 0, 3),
+            BPF_STMT(BPF_LD | BPF_W | BPF_ABS,
+                     offsetof(struct seccomp_data, args[1])),
+            BPF_JUMP(BPF_JMP | BPF_JEQ | BPF_K, 1, 0, 1),
+            BPF_STMT(BPF_RET | BPF_K, SECCOMP_RET_ERRNO | 1),
+            BPF_STMT(BPF_RET | BPF_K, SECCOMP_RET_ALLOW),
+        };
+        struct sock_fprog prog = {
+            .len = sizeof(filter) / sizeof(filter[0]),
+            .filter = filter,
+        };
+        if (syscall(__NR_seccomp, SECCOMP_SET_MODE_FILTER, 0, &prog) < 0) {
+            fprintf(stderr, "seccomp(block SET_DUMPABLE): %s
", strerror(errno));
+        }
+    }
+
     const std::uint64_t RO = LANDLOCK_ACCESS_FS_READ_FILE |
                      LANDLOCK_ACCESS_FS_READ_DIR;
