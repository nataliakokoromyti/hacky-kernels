# Defense for: submission_pipe_interpose.py
# Inode verification of result_fd in BenchmarkManager (manager.h + manager.cpp)
# Detects dup2()-based pipe interposition and reports error instead of timing
#
# Exploit: walks Python stack frames to find 'out_fd', calls dup2() to replace
# the original pipe FD with a filter pipe. A background thread intercepts the
# harness's fprintf output, rewrites timing values to "1.000000" (1us), and
# forwards everything else. No mprotect or memory tricks needed.
#
# Defense: save the result_fd inode at BenchmarkManager construction (before
# user code imports). Before writing timing data, re-check the inode.
# If dup2 replaced the FD, the inode differs → report error-count 99,
# skip timing output. The filter thread passes non-timing lines unchanged,
# so the error is visible to the parent process even through the filter.
#
# Tested: full rebuild of pygpubench on Modal (L4 GPU, CUDA 13.0, Ubuntu 24.04)
# Without patch: [PIPE] filter installed, exploit reports 1.0 us (0 errors)
# With patch:    inode mismatch detected, errors=99, times all -1

--- a/csrc/manager.h
+++ b/csrc/manager.h
@@ -80,6 +80,7 @@
     FILE* mOutputPipe = nullptr;
+    ino_t mResultFdInode = 0;  // inode of result_fd at construction; changes if dup2-replaced

--- a/csrc/manager.cpp
+++ b/csrc/manager.cpp
@@ -1,6 +1,7 @@
 #include <cstdint>
+#include <sys/stat.h>
 ...

@@ constructor @@
     mOutputPipe = fdopen(result_fd, "w");
     if (!mOutputPipe) {
         throw std::runtime_error("Could not open output pipe");
     }
+    // === DEFENSE: save result_fd inode to detect dup2-based pipe interposition ===
+    {
+        struct stat _st;
+        if (fstat(result_fd, &_st) == 0) mResultFdInode = _st.st_ino;
+    }

@@ before writing timing data @@
+    // === DEFENSE: check FD inode before writing timing ===
+    {
+        struct stat _st;
+        bool tampered = (mResultFdInode != 0) &&
+                        (fstat(fileno(mOutputPipe), &_st) == 0) &&
+                        (_st.st_ino != mResultFdInode);
+        if (tampered) {
+            fprintf(stderr, "[DEFENSE] pipe FD inode mismatch — dup2 interception detected\n");
+            fprintf(mOutputPipe, "error-count\t99\n");
+        } else {
     for (int i = 0; i < actual_calls; i++) {
         float duration;
         CUDA_CHECK(cudaEventElapsedTime(&duration, mStartEvents.at(i), mEndEvents.at(i)));
         fprintf(mOutputPipe, "%d\t%f\n", test_order.at(i) - 1, duration * 1000);
     }
+        }
+    }
